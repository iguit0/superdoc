{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "superdoc": ["../../../../packages/superdoc/src/index.js"],
      "superdoc/*": ["../../../../packages/superdoc/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
